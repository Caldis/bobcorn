{
  "name": "bobcorn",
  "productName": "Bobcorn",
  "description": "A tool for build iconfonts.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --publish never",
    "package-all": "electron-vite build && electron-builder -mwl",
    "package-win": "electron-vite build && electron-builder --win --x64",
    "package-linux": "electron-vite build && electron-builder --linux",
    "lint": "eslint app/ --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint app/ --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"app/**/*.{js,jsx,ts,tsx,css,json}\"",
    "test": "jest",
    "test:unit": "jest test/unit"
  },
  "browserslist": [
    "chrome 120"
  ],
  "build": {
    "productName": "Bobcorn",
    "appId": "me.caldis.bobcorn",
    "asar": true,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "identity": null,
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ]
    }
  },
  "author": {
    "name": "10192187|陈标"
  },
  "keywords": [
    "electron",
    "react"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "buffer": "^6.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "events": "^3.3.0",
    "jest": "^27.5.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "process": "^0.11.10",
    "sass": "^1.98.0",
    "stream-browserify": "^3.0.0",
    "stylelint": "^7.10.1",
    "stylelint-config-standard": "^16.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-imp": "^2.4.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^5.29.3",
    "dompurify": "^3.3.3",
    "electron-titlebar-windows": "^3.0.0",
    "memory-fs": "^0.4.1",
    "prop-types": "^15.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.4.1",
    "sql.js": "^1.14.1",
    "svg.js": "^2.6.5",
    "svg2ttf": "^4.0.2",
    "svgicons2svgfont": "^9.0.3",
    "ttf2eot": "^2.0.0",
    "ttf2woff": "^2.0.1",
    "ttf2woff2": "^2.0.3",
    "zustand": "^5.0.11"
  },
  "jest": {
    "transform": {},
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/app/node_modules/"
    ]
  },
  "devEngines": {
    "node": ">=18.x",
    "npm": ">=8.x"
  }
}
